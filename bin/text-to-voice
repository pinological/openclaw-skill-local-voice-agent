#!/bin/bash
# Text-to-Voice - Convert text to speech using Pocket-TTS
# Usage: text-to-voice "Your text here" [output-file] [voice]

set -e

POCKET_TTS_URL="${POCKET_TTS_URL:-http://localhost:5000}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
    echo "🔊 Text-to-Voice - Speech Synthesis"
    echo ""
    echo "Usage: $0 \"<text>\" [output-file] [voice]"
    echo ""
    echo "Arguments:"
    echo "  text          Text to synthesize (in quotes)"
    echo "  output-file   Optional, default=output.wav"
    echo "  voice         Optional, default from config (e.g., 'peter voice', 'voice 2')"
    echo ""
    echo "Environment:"
    echo "  POCKET_TTS_URL  TTS server URL (default: http://localhost:5000)"
    echo ""
    echo "Examples:"
    echo "  $0 \"Hello world!\""
    echo "  $0 \"Hello!\" greeting.wav"
    echo "  $0 \"Namaste!\" nepali.wav \"peter voice\""
    exit 1
}

if [ -z "$1" ]; then
    usage
fi

TEXT="$1"
OUTPUT="${2:-output.wav}"
VOICE="${3:-}"

# Check if TTS server is accessible
if ! curl -s --connect-timeout 5 "$POCKET_TTS_URL/v1/voices" > /dev/null 2>&1; then
    echo -e "${RED}❌ Error: Cannot connect to TTS server at $POCKET_TTS_URL${NC}"
    echo -e "${YELLOW}💡 Start Pocket-TTS server:${NC}"
    echo "   cd /path/to/pockettts"
    echo "   source venv/bin/activate"
    echo "   python3 -m app.main --host 0.0.0.0 --port 5000"
    exit 1
fi

# Get default voice if not specified
if [ -z "$VOICE" ]; then
    VOICE=$(curl -s "$POCKET_TTS_URL/v1/voices" | python3 -c "import sys,json; v=json.load(sys.stdin); print(v['data'][0]['id'] if v['data'] else 'alba')" 2>/dev/null || echo "alba")
fi

echo -e "${YELLOW}🔊 Generating speech...${NC}"
echo -e "${YELLOW}📝 Text: $TEXT${NC}"
echo -e "${YELLOW}🎤 Voice: $VOICE${NC}"
echo -e "${YELLOW}📁 Output: $OUTPUT${NC}"

# Generate speech
RESPONSE=$(curl -s -X POST "$POCKET_TTS_URL/v1/audio/speech" \
  -H "Content-Type: application/json" \
  -d "{\"model\":\"pocket-tts-v1\",\"input\":\"$TEXT\",\"voice\":\"$VOICE\",\"response_format\":\"wav\"}" \
  -o "$OUTPUT" 2>&1)

# Check if output file was created and is valid
if [ -f "$OUTPUT" ] && [ -s "$OUTPUT" ]; then
    # Check if it's actually audio (not JSON error)
    if file "$OUTPUT" | grep -q "WAVE audio"; then
        echo ""
        echo -e "${GREEN}✅ Speech generation complete!${NC}"
        echo -e "${GREEN}📁 File: $OUTPUT ($(ls -lh $OUTPUT | awk '{print $5}'))${NC}"
        echo ""
        echo "▶️  Play with: ffplay $OUTPUT"
    else
        echo -e "${RED}❌ Error: Server returned error${NC}"
        cat "$OUTPUT"
        echo ""
        rm -f "$OUTPUT"
        exit 1
    fi
else
    echo -e "${RED}❌ Error: Failed to generate speech${NC}"
    echo "$RESPONSE"
    exit 1
fi
